    "@tailwindcss/vite": "~4.1.0",
    "@types/gtag.js": "^0.0.18",
    "@types/node": "20.17.0",
    "prettier": "^3.0.0",
    "prettier-plugin-svelte": "^3.0.0",
    "svelte": "^5.29.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "~4.1.0",
    "tslib": "^2.4.1",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
